# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (find it in Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for server-side use)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service-role key (never expose this in the frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Groq (LLM) ──────────────────────────────────────────────────────────────
# API key for Groq Llama-3 — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# ─── Hindsight Memory SDK ─────────────────────────────────────────────────────
# Credentials from your Hindsight Memory dashboard
HINDSIGHT_API_KEY=your-hindsight-api-key
HINDSIGHT_PROJECT_ID=your-hindsight-project-id

# ─── WebSocket / Server ───────────────────────────────────────────────────────
PORT=3000
WEBSOCKET_PORT=8080
WEBSOCKET_HOST=localhost

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
